</div>

<div class="ml-2 mb-2">
  <h5>Phone</h5>
  <span class="ml-2">@(Model.PrivacyOfficer.Phone ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>Phone Extension</h5>
  <span class="ml-2">@(Model.PrivacyOfficer.PhoneExtension ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>Fax</h5>
  <span class="ml-2">@(Model.PrivacyOfficer.Fax ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>SMS Phone</h5>
  <span class="ml-2">@(Model.PrivacyOfficer.SMSPhone ?? "-")</span>
