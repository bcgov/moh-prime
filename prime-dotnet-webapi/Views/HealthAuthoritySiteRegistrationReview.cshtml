  <span class="ml-2">@(Model.TechnicalSupport.JobRoleTitle ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>Name</h5>
  <span class="ml-2">@($"{Model.TechnicalSupport.FirstName} {Model.TechnicalSupport.LastName}" ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>Phone</h5>
  <span class="ml-2">@(Model.TechnicalSupport.Phone ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>Phone Extension</h5>
  <span class="ml-2">@(Model.TechnicalSupport.PhoneExtension ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>Fax</h5>
  <span class="ml-2">@(Model.TechnicalSupport.Fax ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>SMS Phone</h5>
  <span class="ml-2">@(Model.TechnicalSupport.SMSPhone ?? "-")</span>
</div>

<div class="ml-2 mb-2">
  <h5>Email</h5>
  <span class="ml-2">@(Model.TechnicalSupport.Email ?? "-")</span>
</div>